<%- include('../includes/boilerplate.ejs') %>

<div class="form-page">
  <div class="form-card">
    <h2>Add a new stay</h2>
    <p class="subtitle">Fill in the details below to list your property on WanderLust.</p>

    <form method="POST" action="/listings" id="newListingForm">

      <div class="form-group">
        <label>Title</label>
        <input name="listing[title]" placeholder="e.g. Cozy Beachfront Cottage" type="text" required />
      </div>

      <div class="form-group">
        <label>Description</label>
        <textarea name="listing[description]" placeholder="Describe what makes this place special…"></textarea>
      </div>

      <div class="form-group">
        <label>Category</label>
        <select name="listing[category]">
          <% CATEGORIES.forEach(cat => { %>
            <option value="<%= cat %>"><%= cat %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label>Image URL</label>
        <input
          name="listing[image]"
          id="imageInput"
          placeholder="https://images.unsplash.com/…"
          type="url"
        />
        <!-- Live preview -->
        <div class="img-preview-box" id="imgPreview">
          <img id="imgPreviewTag" src="" alt="Preview" />
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Price (₹ / night)</label>
          <input name="listing[price]" placeholder="1200" type="number" min="0" />
        </div>
        <div class="form-group">
          <label>Country</label>
          <input name="listing[country]" placeholder="India" type="text" />
        </div>
      </div>

      <div class="form-group">
        <label>Location / City</label>
        <input name="listing[location]" placeholder="e.g. Goa, Manali, Jaipur" type="text" />
      </div>

      <button class="btn-submit" type="submit">
        <i class="bi bi-plus-circle"></i> Add Listing
      </button>
    </form>

    <p class="form-footer"><a href="/listings">← Back to all listings</a></p>
  </div>
</div>

<%- include('../includes/footer.ejs') %>

<script>
  // Image URL live preview
  const imgInput = document.getElementById('imageInput');
  const imgPreview = document.getElementById('imgPreview');
  const imgPreviewTag = document.getElementById('imgPreviewTag');

  function updatePreview(url) {
    if (url.trim()) {
      imgPreviewTag.src = url.trim();
      imgPreview.classList.add('show');
    } else {
      imgPreview.classList.remove('show');
    }
  }

  imgInput.addEventListener('input', () => updatePreview(imgInput.value));
  imgPreviewTag.addEventListener('error', () => imgPreview.classList.remove('show'));
</script>
