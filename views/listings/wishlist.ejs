<%- include('../includes/boilerplate.ejs') %>

<!-- Hero -->
<section class="wishlist-hero">
  <div class="container">
    <h1><i class="bi bi-heart-fill" style="color:var(--brand);margin-right:.4rem;"></i>My Wishlist</h1>
    <p>Your saved stays — ready for your next adventure.</p>
  </div>
</section>

<main class="container mt-section mb-section">
  <!-- Wishlist grid populated by JS -->
  <div class="listings-grid" id="wishlistGrid">
    <!-- populated by JS -->
  </div>

  <!-- Empty state (shown when no items) -->
  <div id="wishlistEmpty" class="empty-state" style="display:none;">
    <i class="bi bi-heart" style="color:var(--border);"></i>
    <h3>Your wishlist is empty</h3>
    <p>Start exploring listings and tap the ❤️ to save your favourites!</p>
    <a href="/listings" class="btn-brand">Explore Listings</a>
  </div>
</main>

<%- include('../includes/footer.ejs') %>

<script>
  (function () {
    const grid = document.getElementById('wishlistGrid');
    const empty = document.getElementById('wishlistEmpty');
    const WL_KEY = 'wanderlust_wishlist';

    function getWishlist() {
      try { return JSON.parse(localStorage.getItem(WL_KEY) || '[]'); }
      catch (e) { return []; }
    }

    function removeFromWishlist(id) {
      let list = getWishlist();
      list = list.filter(i => i.id !== id);
      localStorage.setItem(WL_KEY, JSON.stringify(list));
      renderWishlist();
      // Update badge
      const badge = document.getElementById('navWlBadge');
      if (badge) {
        if (list.length > 0) { badge.style.display='flex'; badge.textContent=list.length; }
        else badge.style.display='none';
      }
    }

    function starHTML(count) {
      let html = '';
      for (let i = 1; i <= 5; i++) {
        html += `<i class="bi bi-star${i <= count ? '-fill' : ''}" style="color:#F59E0B;font-size:.75rem;"></i>`;
      }
      return html;
    }

    function renderWishlist() {
      const list = getWishlist();
      grid.innerHTML = '';

      if (list.length === 0) {
        empty.style.display = 'block';
        return;
      }
      empty.style.display = 'none';

      list.forEach((item, idx) => {
        const card = document.createElement('div');
        card.className = 'listing-card';
        card.style.animationDelay = (idx * 0.05) + 's';
        card.innerHTML = `
          <div class="card-img-wrap">
            <a href="/listings/${item.id}" style="display:block;">
              <img src="${item.img || ''}" alt="${item.title}"
                   onerror="this.src='https://images.unsplash.com/photo-1625505826533-5c80aca7d157?auto=format&fit=crop&w=800&q=60'"
                   style="width:100%;height:210px;object-fit:cover;" />
            </a>
            <button class="wl-heart saved" data-id="${item.id}" title="Remove from Wishlist" onclick="removeFromWishlist('${item.id}')">
              <i class="bi bi-heart-fill"></i>
            </button>
          </div>
          <a href="/listings/${item.id}" class="card-body" style="text-decoration:none;color:inherit;">
            <div class="card-title">${item.title}</div>
            <div class="card-location">
              <i class="bi bi-geo-alt-fill" style="color:#E8603A;"></i>
              ${item.location}, ${item.country}
            </div>
            <div class="card-price">
              <span>&#8377;${Number(item.price).toLocaleString('en-IN')}</span> / night
            </div>
          </a>
        `;
        grid.appendChild(card);
      });
    }

    // Expose globally for the remove button onclick
    window.removeFromWishlist = removeFromWishlist;
    renderWishlist();
  })();
</script>
